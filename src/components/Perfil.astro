---
import { siteConfig } from "../config";
const { perfil } = siteConfig;
---

<section id="perfil" class="py-16 md:py-24" style="background: var(--color-surface);">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="reveal text-sm font-bold uppercase tracking-widest mb-8 i18n" data-es="Perfil" data-en="Profile" style="color: var(--color-accent);">
      Perfil
    </h2>

    <div class="reveal stagger-1">
      <p class="text-lg md:text-xl leading-relaxed i18n" data-es="Brand Manager con más de 5 años de experiencia en marketing 360°, gestión de marca, desarrollo de campañas on/offline y coordinación con equipos multidisciplinares en entornos B2B y B2C." data-en="Brand Manager with 5+ years of experience in 360° marketing, brand management, on/offline campaign development, and coordination with multidisciplinary teams in B2B and B2C environments." style="color: var(--color-primary-dark);">
        {perfil.intro}
      </p>
    </div>

    <!-- Pull quote -->
    <div class="reveal stagger-2 mt-10">
      <blockquote
        class="quote-float relative pl-6 py-4 border-l-4"
        style="border-color: var(--color-accent);"
      >
        <p class="text-lg md:text-xl italic font-medium i18n" data-es="Busco aportar estrategias de valor en una empresa dinámica donde pueda seguir creciendo." data-en="I seek to bring strategic vision and add value to a growing company." style="color: var(--color-primary);">
          &ldquo;{perfil.quote.text}&rdquo;
        </p>
        <cite class="mt-3 block text-sm font-semibold not-italic" style="color: var(--color-accent);">
          — {perfil.quote.author}
        </cite>
      </blockquote>
    </div>

    <!-- Languages -->
    <div class="reveal stagger-3 mt-10 flex flex-wrap gap-3">
      <span
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium i18n"
        data-es="Español — Nativo"
        data-en="Spanish — Native"
        style="background: white; color: var(--color-primary-dark); border: 1px solid var(--color-primary-light);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M2 12h20"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        Español — Nativo
      </span>
      <span
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium i18n"
        data-es="Inglés — Intermedio Alto (Cambridge B2)"
        data-en="English — Upper Intermediate (Cambridge B2)"
        style="background: white; color: var(--color-primary-dark); border: 1px solid var(--color-primary-light);"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M2 12h20"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        Inglés — Intermedio Alto (Cambridge B2)
      </span>
    </div>
  </div>
</section>
